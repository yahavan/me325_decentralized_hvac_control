!-   =======================  CO2 CONTAMINANT BALANCE  ======================
ZoneAirContaminantBalance, Yes, Outdoor CO2 Schedule, No;

!-   ====================  ZONE TERMINALS & CONNECTIONS  =====================
!-   ConstantVolume:NoReheat terminals: EnergyPlus does NOT modulate them - your
!-   Python driver overrides each one's mass flow (kg/s) every timestep via the
!-   'AirTerminal:SingleDuct:ConstantVolume:NoReheat' / 'Mass Flow Rate' actuator
!-   (key = terminal name). Maximum Air Flow Rate below is the per-zone kg/s ceiling
!-   (entered as m3/s); set your commanded flow anywhere in [0, max].
AirTerminal:SingleDuct:ConstantVolume:NoReheat,
  Zone 1 Air Terminal,        !- Name
  Always On,               !- Availability Schedule Name
  Zone 1 VAV Inlet Node,      !- Air Inlet Node Name (from zone splitter)
  Zone 1 Supply Inlet Node,   !- Air Outlet Node Name (into zone)
  0.5;          !- Maximum Air Flow Rate {m3/s}
ZoneHVAC:AirDistributionUnit,
  Zone 1 ADU, Zone 1 Supply Inlet Node, AirTerminal:SingleDuct:ConstantVolume:NoReheat, Zone 1 Air Terminal;
ZoneHVAC:EquipmentList,
  Zone 1 Equipment, SequentialLoad, ZoneHVAC:AirDistributionUnit, Zone 1 ADU, 1, 1, , ;
ZoneHVAC:EquipmentConnections,
  Zone 1, Zone 1 Equipment, Zone 1 Supply Inlet Node, , Zone 1 Air Node, Zone 1 Return Node;

AirTerminal:SingleDuct:ConstantVolume:NoReheat,
  Zone 2 Air Terminal,        !- Name
  Always On,               !- Availability Schedule Name
  Zone 2 VAV Inlet Node,      !- Air Inlet Node Name (from zone splitter)
  Zone 2 Supply Inlet Node,   !- Air Outlet Node Name (into zone)
  0.35;          !- Maximum Air Flow Rate {m3/s}
ZoneHVAC:AirDistributionUnit,
  Zone 2 ADU, Zone 2 Supply Inlet Node, AirTerminal:SingleDuct:ConstantVolume:NoReheat, Zone 2 Air Terminal;
ZoneHVAC:EquipmentList,
  Zone 2 Equipment, SequentialLoad, ZoneHVAC:AirDistributionUnit, Zone 2 ADU, 1, 1, , ;
ZoneHVAC:EquipmentConnections,
  Zone 2, Zone 2 Equipment, Zone 2 Supply Inlet Node, , Zone 2 Air Node, Zone 2 Return Node;

AirTerminal:SingleDuct:ConstantVolume:NoReheat,
  Zone 3 Air Terminal,        !- Name
  Always On,               !- Availability Schedule Name
  Zone 3 VAV Inlet Node,      !- Air Inlet Node Name (from zone splitter)
  Zone 3 Supply Inlet Node,   !- Air Outlet Node Name (into zone)
  0.55;          !- Maximum Air Flow Rate {m3/s}
ZoneHVAC:AirDistributionUnit,
  Zone 3 ADU, Zone 3 Supply Inlet Node, AirTerminal:SingleDuct:ConstantVolume:NoReheat, Zone 3 Air Terminal;
ZoneHVAC:EquipmentList,
  Zone 3 Equipment, SequentialLoad, ZoneHVAC:AirDistributionUnit, Zone 3 ADU, 1, 1, , ;
ZoneHVAC:EquipmentConnections,
  Zone 3, Zone 3 Equipment, Zone 3 Supply Inlet Node, , Zone 3 Air Node, Zone 3 Return Node;

AirTerminal:SingleDuct:ConstantVolume:NoReheat,
  Zone 4 Air Terminal,        !- Name
  Always On,               !- Availability Schedule Name
  Zone 4 VAV Inlet Node,      !- Air Inlet Node Name (from zone splitter)
  Zone 4 Supply Inlet Node,   !- Air Outlet Node Name (into zone)
  0.6;          !- Maximum Air Flow Rate {m3/s}
ZoneHVAC:AirDistributionUnit,
  Zone 4 ADU, Zone 4 Supply Inlet Node, AirTerminal:SingleDuct:ConstantVolume:NoReheat, Zone 4 Air Terminal;
ZoneHVAC:EquipmentList,
  Zone 4 Equipment, SequentialLoad, ZoneHVAC:AirDistributionUnit, Zone 4 ADU, 1, 1, , ;
ZoneHVAC:EquipmentConnections,
  Zone 4, Zone 4 Equipment, Zone 4 Supply Inlet Node, , Zone 4 Air Node, Zone 4 Return Node;

AirTerminal:SingleDuct:ConstantVolume:NoReheat,
  Zone 5 Air Terminal,        !- Name
  Always On,               !- Availability Schedule Name
  Zone 5 VAV Inlet Node,      !- Air Inlet Node Name (from zone splitter)
  Zone 5 Supply Inlet Node,   !- Air Outlet Node Name (into zone)
  0.35;          !- Maximum Air Flow Rate {m3/s}
ZoneHVAC:AirDistributionUnit,
