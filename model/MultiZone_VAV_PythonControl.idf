!-   ==========================================================================
!-   Multi-Zone VAV System  -  CONTROL-FREE plant for runtime Python control
!-   5 thermal zones | DX cooling AHU | CO2 contaminant balance
!-   No EMS / no hardcoded control. Drive via the EnergyPlus Python API:
!-     * central SAT setpoint  -> actuator on 'DX Coil Outlet Node'
!-     * per-zone airflow       -> 'Mass Flow Rate' on each terminal (kg/s, key=terminal)
!-     * per-zone setpoints      -> 'Zone Temperature Control' Heating/Cooling
!-     * outdoor-air flow        -> 'Outdoor Air Controller' Air Mass Flow Rate
!-   Climate: Colombo, Sri Lanka (hot & humid). Requires a Colombo .epw at run time.
!-   ==========================================================================

Version, 25.2;

SimulationControl,
  Yes,                     !- Do Zone Sizing Calculation
  Yes,                     !- Do System Sizing Calculation
  No,                      !- Do Plant Sizing Calculation
  No,                      !- Run Simulation for Sizing Periods
  Yes,                     !- Run Simulation for Weather File Run Periods
  No,                      !- Do HVAC Sizing Simulation for Sizing Periods
  1;                       !- Maximum Number of HVAC Sizing Simulation Passes

Building,
  Multi-Zone VAV Building,  !- Name
  0.0,                     !- North Axis {deg}
  City,                    !- Terrain
  0.04,                    !- Loads Convergence Tolerance Value
  0.40,                    !- Temperature Convergence Tolerance Value {deltaC}
  FullExterior,            !- Solar Distribution
  25,                      !- Maximum Number of Warmup Days
  6;                       !- Minimum Number of Warmup Days

Timestep, 6;

GlobalGeometryRules,
  UpperLeftCorner,         !- Starting Vertex Position
  Counterclockwise,        !- Vertex Entry Direction
  World;                   !- Coordinate System

Site:Location,
  Colombo Sri Lanka,       !- Name
  6.90,                    !- Latitude {deg}
  79.86,                   !- Longitude {deg}
  5.5,                     !- Time Zone {hr}
  7.0;                     !- Elevation {m}

SizingPeriod:DesignDay,
  Colombo Cooling Design Day,  !- Name
  4, 21, SummerDesignDay,  !- Month / Day / Day Type
  33.0,                    !- Maximum Dry-Bulb Temperature {C}
  7.0,                     !- Daily Dry-Bulb Temperature Range {deltaC}
  , ,                      !- Range Modifier Type / Schedule
  Wetbulb,                 !- Humidity Condition Type
  27.0,                    !- Wetbulb at Maximum Dry-Bulb {C}
  , , , ,                  !- (humidity schedule / ratio / enthalpy / wb range)
  101200.,                 !- Barometric Pressure {Pa}
  3.0,                     !- Wind Speed {m/s}
  0.,                      !- Wind Direction {deg}
  No, No, No,              !- Rain / Snow / Daylight Saving
  ASHRAEClearSky,          !- Solar Model Indicator
  , , , ,                  !- (solar schedules / taub / taud)
  1.0;                     !- Sky Clearness

SizingPeriod:DesignDay,
  Colombo Heating Design Day,  !- Name
  1, 21, WinterDesignDay,  !- Month / Day / Day Type
  22.0,                    !- Maximum Dry-Bulb Temperature {C}
  0.0,                     !- Daily Dry-Bulb Temperature Range {deltaC}
  , ,                      !- Range Modifier Type / Schedule
  Wetbulb,                 !- Humidity Condition Type
  21.0,                    !- Wetbulb at Maximum Dry-Bulb {C}
  , , , ,                  !- (humidity schedule / ratio / enthalpy / wb range)
  101200.,                 !- Barometric Pressure {Pa}
  3.0,                     !- Wind Speed {m/s}
  0.,                      !- Wind Direction {deg}
  No, No, No,              !- Rain / Snow / Daylight Saving
  ASHRAEClearSky,          !- Solar Model Indicator
  , , , ,                  !- (solar schedules / taub / taud)
  0.0;                     !- Sky Clearness

RunPeriod,
  Annual Run,              !- Name
  1, 1, ,                  !- Begin Month / Day / Year
  12, 31, ,                !- End Month / Day / Year
  Monday,                  !- Day of Week for Start Day
  Yes, Yes, No, Yes, Yes;  !- Wx holidays / DST / weekend rule / rain / snow

Sizing:Parameters, 1.2, 1.2;

!-   ============================  SCHEDULES  ===============================
!-   Setpoint schedules below are INITIAL DEFAULTS only. Python overrides them
!-   each timestep through the actuators; they exist so the model is valid and
!-   can warm up / size before your controller takes over.
ScheduleTypeLimits, Fraction, 0.0, 1.0, Continuous;
ScheduleTypeLimits, Temperature, -60.0, 200.0, Continuous, Temperature;
ScheduleTypeLimits, ControlType, 0, 4, Discrete;
ScheduleTypeLimits, AnyNumber;
ScheduleTypeLimits, ActivityLevel, 0.0, , Continuous, ActivityLevel;

Schedule:Constant, Always On, Fraction, 1.0;
Schedule:Constant, Activity Level, ActivityLevel, 120.0;
Schedule:Constant, Heating SP Sched, Temperature, 18.0;
Schedule:Constant, Control Type Sched, ControlType, 4;
Schedule:Constant, Outdoor CO2 Schedule, AnyNumber, 400.0;
Schedule:Constant, SAT Setpoint Schedule, Temperature, 13.0;
Schedule:Constant, Server Equipment Sched, Fraction, 0.90;

Schedule:Compact, Office Occupancy, Fraction,
  Through: 12/31, For: Weekdays SummerDesignDay,
  Until: 08:00, 0.05, Until: 18:00, 1.00, Until: 24:00, 0.05,
  For: AllOtherDays, Until: 24:00, 0.0;

Schedule:Compact, Office Lighting, Fraction,
  Through: 12/31, For: Weekdays SummerDesignDay,
  Until: 08:00, 0.10, Until: 18:00, 0.90, Until: 24:00, 0.10,
  For: AllOtherDays, Until: 24:00, 0.05;

Schedule:Compact, Office Equipment, Fraction,
  Through: 12/31, For: Weekdays SummerDesignDay,
  Until: 08:00, 0.30, Until: 18:00, 0.90, Until: 24:00, 0.30,
  For: AllOtherDays, Until: 24:00, 0.20;

Schedule:Constant, Zone 1 Cooling SP Sched, Temperature, 24.0;
Schedule:Constant, Zone 2 Cooling SP Sched, Temperature, 24.0;
Schedule:Constant, Zone 3 Cooling SP Sched, Temperature, 23.0;
Schedule:Constant, Zone 4 Cooling SP Sched, Temperature, 21.0;
Schedule:Constant, Zone 5 Cooling SP Sched, Temperature, 24.0;

!-   ======================  MATERIALS / CONSTRUCTIONS  =====================
Material, M_Stucco, MediumRough, 0.025, 0.72, 1856.0, 840.0, 0.90, 0.92, 0.92;
Material, M_Concrete200, MediumRough, 0.20, 1.95, 2240.0, 900.0, 0.90, 0.70, 0.70;
Material, M_Insulation, MediumRough, 0.075, 0.049, 265.0, 836.0, 0.90, 0.70, 0.70;
Material, M_Gypsum, Smooth, 0.016, 0.16, 800.0, 1090.0, 0.90, 0.50, 0.50;
Material, M_RoofMembrane, VeryRough, 0.010, 0.16, 1120.0, 1460.0, 0.90, 0.70, 0.70;
Material, M_RoofInsulation, MediumRough, 0.12, 0.049, 265.0, 836.0, 0.90, 0.70, 0.70;
Material, M_FloorSlab, MediumRough, 0.10, 1.31, 2240.0, 900.0, 0.90, 0.70, 0.70;

WindowMaterial:SimpleGlazingSystem, SimpleGlazing, 3.0, 0.40, 0.60;

Construction, Exterior Wall, M_Stucco, M_Concrete200, M_Insulation, M_Gypsum;
Construction, Interior Wall, M_Gypsum, M_Gypsum;
Construction, Roof, M_RoofMembrane, M_RoofInsulation, M_Concrete200;
Construction, Floor, M_FloorSlab;
Construction, Exterior Window, SimpleGlazing;

