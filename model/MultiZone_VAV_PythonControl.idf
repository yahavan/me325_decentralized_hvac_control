!-   ===========================  AIR LOOP (AHU)  ===========================
AirLoopHVAC,
  VAV Air Loop, ,            !- Name / Controller List Name
  VAV Availability Managers, !- Availability Manager List Name
  autosize,                  !- Design Supply Air Flow Rate
  VAV Branch List, ,         !- Branch List Name / Connector List Name
  VAV Supply Inlet Node,     !- Supply Side Inlet Node Name
  VAV Return Air Node,       !- Demand Side Outlet Node Name
  VAV Demand Inlet Node,     !- Demand Side Inlet Node Names
  VAV Supply Outlet Node;    !- Supply Side Outlet Node Names

BranchList, VAV Branch List, VAV Supply Branch;

Branch,
  VAV Supply Branch, ,
  AirLoopHVAC:OutdoorAirSystem, VAV OA System, VAV Supply Inlet Node, OA Mixer Outlet Node,
  CoilSystem:Cooling:DX, VAV DX Coil System, OA Mixer Outlet Node, DX Coil Outlet Node,
  Fan:VariableVolume, VAV Supply Fan, DX Coil Outlet Node, VAV Supply Outlet Node;

AvailabilityManager:Scheduled, VAV Avail Mgr, Always On;
AvailabilityManagerAssignmentList, VAV Availability Managers, AvailabilityManager:Scheduled, VAV Avail Mgr;

AirLoopHVAC:OutdoorAirSystem,
  VAV OA System, VAV OA Controller List, VAV OA Equipment List;
AirLoopHVAC:ControllerList,
  VAV OA Controller List, Controller:OutdoorAir, VAV OA Controller;
AirLoopHVAC:OutdoorAirSystem:EquipmentList,
  VAV OA Equipment List, OutdoorAir:Mixer, VAV OA Mixer;

OutdoorAir:Mixer,
  VAV OA Mixer, OA Mixer Outlet Node, OA Inlet Node, Relief Air Node, VAV Supply Inlet Node;
OutdoorAir:Node, OA Inlet Node, -1.0;

Controller:OutdoorAir,
  VAV OA Controller,        !- Name
  Relief Air Node,          !- Relief Air Outlet Node Name
  VAV Supply Inlet Node,    !- Return Air Node Name
  OA Mixer Outlet Node,     !- Mixed Air Node Name
  OA Inlet Node,            !- Actuator Node Name
  autosize,                 !- Minimum Outdoor Air Flow Rate
  autosize,                 !- Maximum Outdoor Air Flow Rate
  NoEconomizer,             !- Economizer Control Type
  ModulateFlow,             !- Economizer Control Action Type
  , , , , ,                 !- (economizer limits)
  NoLockout,                !- Lockout Type
  FixedMinimum;             !- Minimum Limit Type

CoilSystem:Cooling:DX,
  VAV DX Coil System, Always On,
  OA Mixer Outlet Node,     !- DX Cooling Coil System Inlet Node Name
  DX Coil Outlet Node,      !- DX Cooling Coil System Outlet Node Name
  DX Coil Outlet Node,      !- Sensor Node Name (where the SAT setpoint lives)
  Coil:Cooling:DX:SingleSpeed, VAV DX Cooling Coil,
  None, Yes, No;            !- Dehumidification Control / Run on Sensible / Latent

Coil:Cooling:DX:SingleSpeed,
  VAV DX Cooling Coil, Always On,
  autosize,                 !- Gross Rated Total Cooling Capacity {W}
  autosize,                 !- Gross Rated Sensible Heat Ratio
  3.5,                      !- Gross Rated Cooling COP {W/W}
  autosize,                 !- Rated Air Flow Rate {m3/s}
  , ,                       !- 2017 / 2023 Rated Evap Fan Power Per Flow
  OA Mixer Outlet Node,     !- Air Inlet Node Name
  DX Coil Outlet Node,      !- Air Outlet Node Name
  DX CapFT, DX CapFFF, DX EIRFT, DX EIRFFF, DX PLF;

Curve:Biquadratic, DX CapFT, 0.942587793, 0.009543347, 0.000683770,
  -0.011042676, 0.000005249, -0.000009720, 17.0, 22.0, 13.0, 46.0;
Curve:Quadratic, DX CapFFF, 0.8, 0.2, 0.0, 0.5, 1.5;
Curve:Biquadratic, DX EIRFT, 0.342414409, 0.034885008, -0.000623700,
  0.004977216, 0.000437951, -0.000728028, 17.0, 22.0, 13.0, 46.0;
Curve:Quadratic, DX EIRFFF, 1.1552, -0.1808, 0.0256, 0.5, 1.5;
Curve:Quadratic, DX PLF, 0.85, 0.15, 0.0, 0.0, 1.0;

Fan:VariableVolume,
  VAV Supply Fan, Always On,
  0.7, 600.0, autosize,     !- Efficiency / Pressure Rise {Pa} / Max Flow {m3/s}
  Fraction, 0.25, ,         !- Min Flow Method / Fraction / Min Flow Rate
  0.9, 1.0,                 !- Motor Efficiency / Motor In Airstream Fraction
  0.0407, 0.08804, -0.07292, 0.9433, 0.0,  !- Fan Power Coefficients 1-5
  DX Coil Outlet Node, VAV Supply Outlet Node, General;

!-   SAT setpoint manager = INITIAL DEFAULT (13 C). Python overrides the setpoint at
!-   'DX Coil Outlet Node' each timestep via the System Node Setpoint actuator.
SetpointManager:Scheduled,
  VAV SAT Manager, Temperature, SAT Setpoint Schedule, DX Coil Outlet Node;

AirLoopHVAC:SupplyPath,
  VAV Supply Path, VAV Demand Inlet Node, AirLoopHVAC:ZoneSplitter, VAV Zone Splitter;
AirLoopHVAC:ZoneSplitter,
  VAV Zone Splitter, VAV Demand Inlet Node,
  Zone 1 VAV Inlet Node, Zone 2 VAV Inlet Node, Zone 3 VAV Inlet Node, Zone 4 VAV Inlet Node, Zone 5 VAV Inlet Node;

AirLoopHVAC:ReturnPath,
  VAV Return Path, VAV Return Air Node, AirLoopHVAC:ZoneMixer, VAV Zone Mixer;
AirLoopHVAC:ZoneMixer,
  VAV Zone Mixer, VAV Return Air Node,
  Zone 1 Return Node, Zone 2 Return Node, Zone 3 Return Node, Zone 4 Return Node, Zone 5 Return Node;

Sizing:System,
  VAV Air Loop, Sensible, autosize, 0.3,
  7.0, 0.008, 12.8, 0.008,  !- Preheat T/W, Precool T/W
  13.0, 40.0,               !- Central Cooling / Heating Design Supply Air Temp
  NonCoincident, No, No,    !- Zone Sum / 100% OA Cooling / Heating
  0.0085, 0.008,            !- Central Cooling / Heating Supply Air Humidity Ratio
  DesignDay, 0.0, , , ,     !- Cooling Supply Air Flow method
  DesignDay, 0.0, , , , ,   !- Heating Supply Air Flow method
  ZoneSum, 1.0,             !- System OA Method / Zone Max OA Fraction
  CoolingDesignCapacity, autosize, , ,
  HeatingDesignCapacity, autosize, , ,
  OnOff;

!-   ============================  OUTPUT  ==================================
!-   IMPORTANT: the EnergyPlus Python API can only read a variable that is
!-   requested below (get_variable_handle needs an Output:Variable to exist).
!-   Actuators do NOT need any object - request handles directly in Python via
!-   get_actuator_handle(component_type, control_type, key). To discover exact
!-   handle strings for your build, call api.exchange.list_available_api_data_csv().
Output:VariableDictionary, IDF;
OutputControl:Table:Style, HTML;
Output:Table:SummaryReports, AllSummary;

!-   --- Zone states (controller inputs: T, humidity ratio, RH, CO2) ---
Output:Variable, *, Zone Mean Air Temperature, Timestep;
Output:Variable, *, Zone Air Humidity Ratio, Timestep;
Output:Variable, *, Zone Air Relative Humidity, Timestep;
Output:Variable, *, Zone Air CO2 Concentration, Timestep;

!-   --- Thermostat setpoints (verify your per-zone setpoint writes) ---
Output:Variable, *, Zone Thermostat Cooling Setpoint Temperature, Timestep;
Output:Variable, *, Zone Thermostat Heating Setpoint Temperature, Timestep;

!-   --- terminal / airflow (your commanded flow lands on the zone supply node) ---
Output:Variable, *, System Node Mass Flow Rate, Timestep;
Output:Variable, *, System Node Temperature, Timestep;
Output:Variable, *, System Node Relative Humidity, Timestep;
Output:Variable, *, System Node Humidity Ratio, Timestep;
Output:Variable, *, System Node Setpoint Temperature, Timestep;
Output:Variable, *, System Node CO2 Concentration, Timestep;

!-   --- Outdoor conditions / OA flow ---
Output:Variable, *, Site Outdoor Air Drybulb Temperature, Timestep;
Output:Variable, *, Site Outdoor Air Humidity Ratio, Timestep;
Output:Variable, *, Air System Outdoor Air Mass Flow Rate, Timestep;

!-   --- Energy surrogates (fan + coil) ---
Output:Variable, *, Fan Electricity Rate, Timestep;
Output:Variable, *, Cooling Coil Electricity Rate, Timestep;
Output:Variable, *, Cooling Coil Total Cooling Rate, Timestep;
Output:Variable, *, Cooling Coil Sensible Cooling Rate, Timestep;
Output:Variable, *, Cooling Coil Latent Cooling Rate, Timestep;

